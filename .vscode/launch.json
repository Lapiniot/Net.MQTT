{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MQTT Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "PreBuildServer",
            "program": "${workspaceFolder}/artifacts/bin/Mqtt.Server/debug_net10.0/mqtt-server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Mqtt.Server",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "logging": {
                "moduleLoad": false,
                "exceptions": false
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_Kestrel__Endpoints__mqtt-uds-kestrel__Url": "http://unix:/tmp/mqtt-kestrel.sock",
                "MQTT_MQTT__Endpoints__unix-socket__Url": "unix:///tmp/mqtt.sock"
            },
            "windows": {
                "env": {
                    "ASPNETCORE_Kestrel__Endpoints__mqtt-uds-kestrel__Url": "http://unix:/%TEMP%\\mqtt-kestrel.sock",
                    "MQTT_MQTT__Endpoints__unix-socket__Url": "unix:///%TEMP%\\mqtt.sock"
                }
            },
            "osx": {
                "env": {
                    "DYLD_FALLBACK_LIBRARY_PATH": "$DYLD_FALLBACK_LIBRARY_PATH:/usr/local/lib"
                }
            }
        },
        {
            "name": "MQTT Benchmark",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "PreBuildBenchmark",
            "program": "${workspaceFolder}/artifacts/bin/Mqtt.Benchmark/debug_net10.0/mqtt-benchmark.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Mqtt.Benchmark",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "logging": {
                "moduleLoad": false,
                "exceptions": false
            }
        },
        {
            "name": "C#: Client [default]",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/Samples/Client/Client.csproj",
            "launchConfigurationId": "TargetFramework=net10.0;default",
            "osx": {
                "launchConfigurationId": "TargetFramework=net10.0;default (osx)"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}